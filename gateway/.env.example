# ============================================================
# banproof-core Gateway — Environment Variables Reference
# Copy this file to .dev.vars for local development.
# Never commit actual secrets to the repository.
# ============================================================

# ── JWT (required for auth) ───────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
# Upload to production: wrangler secret put JWT_SECRET
JWT_SECRET=dev-secret-for-testing-only

# ── Mock Toggle ───────────────────────────────────────────────
# Set to "false" only after manual UI verification
USE_MOCK=true
ENVIRONMENT=development

# ── Cloudflare bindings (auto-injected by wrangler) ──────────
# DB, CACHE, ENGINE, AI provided via wrangler.toml bindings.
# These are not set as env vars — they are worker bindings.

# ── HuggingFace (optional when USE_MOCK=true) ────────────────
# https://huggingface.co/settings/tokens
HF_API_TOKEN=

# ── Odds API (optional when USE_MOCK=true) ───────────────────
# https://the-odds-api.com/account/
ODDS_API_KEY=

# ── Discord Notifications (optional) ─────────────────────────
# Server Settings → Integrations → Webhooks → Copy Webhook URL
DISCORD_WEBHOOK=

# ── Stripe (for future billing) ──────────────────────────────
# dashboard.stripe.com → Developers → API keys
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ── CORS origins (comma-separated allowlist) ─────────────────
# Defaults: https://banproof.me,http://localhost:5500
CORS_ORIGINS=https://banproof.me,http://localhost:5500,http://localhost:8788
# Banproof Core — Local Development Environment Template
# Copy this file to .dev.vars for wrangler dev usage.
# ============================================================

# Cloudflare Bindings are provided automatically by wrangler.toml:
#   DB             → D1 database (bp-core-prod)
#   CACHE          → KV namespace
#   INFRA_SECRETS  → KV namespace
#   ENGINE         → Workflow binding

# ── API Keys (leave empty if USE_MOCK=true) ──────────────────
HF_API_TOKEN=
ODDS_API_KEY=

# ── Discord Webhook (optional) ───────────────────────────────
# If unset, workflow logs to console instead of Discord.
DISCORD_WEBHOOK=

# ── Toggle Mock / Real APIs ───────────────────────────────────
# "true"  → use randomised mock data (safe for development)
# "false" → call real Hugging Face + Odds API (requires keys above)
USE_MOCK=true
