# ============================================================
# .env.example — Banproof Core Gateway
# ============================================================
# Copy this file to .env (git-ignored) and fill in values
# for local development with `wrangler dev`.
#
# For production secrets, use:
#   wrangler secret put <KEY_NAME> --config gateway/wrangler.toml
# ============================================================

# ── Cloudflare Access (Zero-Edge SSO) ────────────────────────
# The audience tag for your Cloudflare Access application.
# Found at: dash.cloudflare.com → Access → Applications → <app> → Overview
CF_ACCESS_AUDIENCE=https://banproof-core.marzton.workers.dev

# The App ID for your Cloudflare Access application.
CF_ACCESS_APP_ID=your-app-id-here

# RSA public key for validating Cf-Access-Jwt-Assertion tokens.
# Retrieve from: https://<team>.cloudflareaccess.com/cdn-cgi/access/certs
# Paste the PEM-encoded public key (include BEGIN/END lines).
CF_ZERO_EDGE_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----
...paste your public key here...
-----END PUBLIC KEY-----

# ── Role Definitions (JSON) ───────────────────────────────────
# Optional / legacy: maps role names to groups for RBAC. The current
# RBAC implementation is hard-coded (ROLE_LEVELS in zeroEdgeSSO.ts)
# and does not read this variable.
ROLE_DEFINITIONS={"admin":["admin"],"pro":["pro","agency"],"free":["free","public"]}

# ── Admin IP Whitelist ────────────────────────────────────────
# Comma-separated list of trusted IPs for /admin/config (POST).
# Defaults to Tailscale DePIN nodes + localhost if not set.
TRUSTED_ADMIN_IPS=100.100.100.1,100.200.200.2,127.0.0.1,::1

# ── Cloudflare Account (wrangler) ─────────────────────────────
# dash.cloudflare.com → right sidebar on any zone overview page
CF_ACCOUNT_ID=your-cloudflare-account-id

# dash.cloudflare.com → My Profile → API Tokens → Create Token
CF_API_TOKEN=your-cloudflare-api-token

# ── GitHub PAT ───────────────────────────────────────────────
# github.com → Settings → Developer settings → Fine-grained tokens
# Permissions: Contents (read), Actions (read), Metadata (read)
GH_PAT=

# ── Environment ──────────────────────────────────────────────
ENVIRONMENT=development
